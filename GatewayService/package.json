{
  "name": "memoq-ai-gateway",
  "private": true,
  "version": "1.0.0",
  "author": "LangLink Localization",
  "description": "Local Electron gateway service for memoQ AI MT/TM/TB/QA orchestration.",
  "main": ".vite/build/main.js",
  "files": [
    ".vite/**/*",
    "src/**/*",
    "node_modules/**/*",
    "package.json"
  ],
  "scripts": {
    "start": "electron-forge start",
    "start:server": "node src/server.js",
    "smoke:health": "node src/smokeHealthCheck.js",
    "test": "node --test --experimental-test-isolation=none test/*.test.js",
    "lint": "node -e \"console.log('No linter configured yet.')\"",
    "prepare:release": "powershell -ExecutionPolicy Bypass -File ..\\build\\prepare-desktop-release.ps1 -Configuration Release",
    "prepare:litellm": "powershell -ExecutionPolicy Bypass -File ..\\build\\prepare-litellm-runtime.ps1",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "dist:win:dir": "electron-forge package --platform win32",
    "dist:win": "electron-forge make --platform win32",
    "zip:win-unpacked": "powershell -ExecutionPolicy Bypass -File ..\\build\\zip-win-unpacked.ps1"
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "electron-store": "^8.2.0",
    "express": "^4.19.2",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.6.1",
    "@electron-forge/maker-squirrel": "^7.6.1",
    "@electron-forge/maker-zip": "^7.6.1",
    "@electron-forge/plugin-vite": "^7.6.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "electron": "^30.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.7"
  }
}
